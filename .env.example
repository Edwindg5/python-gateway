# Secreto usado para validar la firma HS256 de los JWT (mobile y web).
JWT_SECRET=

# URL base del backend api-mobile (Go). El gateway reenvia todo lo que llega a /mobile/*.
API_MOBILE_URL=http://api-mobile:8080

# URL base del backend api-web (FastAPI). El gateway reenvia todo lo que llega a /web/*.
API_WEB_URL=http://api-web:8000

# URL base del backend de pagos (microservicio-pay). El gateway reenvia todo lo que llega a /pagos/*.
PAGOS_URL=http://localhost:8082

# Puerto en el que escucha el gateway.
PORT=8090

# Origen(es) permitido(s) para CORS. "*" es temporal para no bloquear la
# entrega; hay que restringirlo a los dominios reales del frontend despues.
CORS_ALLOWED_ORIGIN=*
